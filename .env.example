# Local Development Environment Variables
# Copy this file to .env and update values for your local setup
# .env files are gitignored and should never be committed

# ============================================
# Logging Configuration
# ============================================
# Elasticsearch URL for centralized log aggregation (optional)
# Leave empty to disable Elasticsearch and use only local file/console logging
Logging__Elasticsearch__Url=http://localhost:9200

# ============================================
# Observability & Tracing
# ============================================
# OTEL Collector endpoint for distributed tracing
# Local dev: http://localhost:4317 (Jaeger)
# Docker: http://jaeger:4317
Observability__OtlpEndpoint=http://localhost:4317
Observability__EnableConsoleExporter=false

# ============================================
# Database Connections
# ============================================
# Override these to point to local PostgreSQL when running services locally
# Default: connects to localhost:5432 (from docker-compose)
# In docker-compose, use: postgres (service name)

# Pet Service
ConnectionStrings__DefaultConnection="Host=localhost;Database=PetServiceDb;Username=postgres;Password=PetApp123!@#;Port=5432;"

# Identity Service
ConnectionStrings__IdentityServiceDb="Host=localhost;Database=PetApp.IdentityService;Username=postgres;Password=PetApp123!@#;Port=5432;"

# User Profile Service
ConnectionStrings__UserProfileServiceDb="Host=localhost;Database=PetApp.UserProfileService;Username=postgres;Password=PetApp123!@#;Port=5432;"

# File Service
ConnectionStrings__FileServiceDb="Host=localhost;Database=PetApp.FileService;Username=postgres;Password=PetApp123!@#;Port=5432;"

# Notification Service
ConnectionStrings__NotificationServiceDb="Host=localhost;Database=PetApp.NotificationService;Username=postgres;Password=PetApp123!@#;Port=5432;"

# ============================================
# JWT Settings (Identity Service)
# ============================================
# Secret key must be at least 32 characters for 256-bit encryption
# Generate a secure key: `dotnet user-secrets init && dotnet user-secrets set "JwtSettings:SecretKey" "your-min-32-char-secret"`
JwtSettings__SecretKey="your-super-secret-key-that-is-at-least-32-characters-long-for-256bit"
JwtSettings__Issuer=pet-app-identity-service
JwtSettings__Audience=pet-app-api
JwtSettings__AccessTokenExpirationMinutes=15
JwtSettings__RefreshTokenExpirationMinutes=10080

# ============================================
# OAuth Settings (Social Authentication)
# ============================================
# Google OAuth
OAuthSettings__ClientIds__google=YOUR_GOOGLE_CLIENT_ID
OAuthSettings__ClientSecrets__google=YOUR_GOOGLE_CLIENT_SECRET

# Facebook OAuth
OAuthSettings__ClientIds__facebook=YOUR_FACEBOOK_APP_ID
OAuthSettings__ClientSecrets__facebook=YOUR_FACEBOOK_APP_SECRET

# Apple OAuth
OAuthSettings__ClientIds__apple=YOUR_APPLE_TEAM_ID
OAuthSettings__ClientSecrets__apple=YOUR_APPLE_KEY_ID

# ============================================
# Message Bus (RabbitMQ for Local, Azure Service Bus for Production)
# ============================================
# Local RabbitMQ (amqp protocol)
ConnectionStrings__AzureServiceBus="amqp://guest:guest@localhost:5672/"

# Production: Use Azure Service Bus connection string
# ConnectionStrings__AzureServiceBus=Endpoint=sb://your-namespace.servicebus.windows.net/;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=your-key

# ============================================
# ASP.NET Core
# ============================================
# Use Development to enable detailed logging and skip HTTPS redirect
ASPNETCORE_ENVIRONMENT=Development

# Disable SSL certificate validation errors in Development
# Remove or set to false in test/prod
DOTNET_SYSTEM_NET_HTTP_USESOCKETSHTTPHANDLER=0

# ============================================
# Elasticsearch Configuration (if using)
# ============================================
# Index retention and settings
Logging__LogRetentionDays=30

# ============================================
# Email Configuration (Notification Service)
# ============================================
# Email provider: sendgrid, smtp, or console
Email__UseReal=false
Email__Provider=sendgrid
Email__FromAddress=noreply@petapp.example.com
Email__FromName="Pet App"
Email__SendGridApiKey=SG.your-sendgrid-api-key

# SMTP Configuration (required if Provider=smtp)
Email__SmtpHost=localhost
Email__SmtpPort=587
Email__SmtpUsername=
Email__SmtpPassword=
Email__SmtpEnableSsl=true
