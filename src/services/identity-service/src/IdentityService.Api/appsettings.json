{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    },
    "EnableSqlLogging": false
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "IdentityServiceDb": "Server=(localdb)\\mssqllocaldb;Database=PetApp.IdentityService;Trusted_Connection=true;"
  },
  "JwtSettings": {
    "SecretKey": "your-super-secret-key-that-is-at-least-32-characters-long-for-256bit",
    "Issuer": "pet-app-identity-service",
    "Audience": "pet-app-api",
    "AccessTokenExpirationMinutes": 15,
    "RefreshTokenExpirationMinutes": 10080
  },
  "OAuthSettings": {
    "ClientIds": {
      "google": "YOUR_GOOGLE_CLIENT_ID",
      "facebook": "YOUR_FACEBOOK_APP_ID",
      "apple": "YOUR_APPLE_TEAM_ID"
    },
    "ClientSecrets": {
      "google": "YOUR_GOOGLE_CLIENT_SECRET",
      "facebook": "YOUR_FACEBOOK_APP_SECRET",
      "apple": "YOUR_APPLE_KEY_ID"
    }
  },
  "AzureServiceBus": {
    "ConnectionString": "Endpoint=sb://your-namespace.servicebus.windows.net/;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=your-key"
  }
}
