{
  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "Match": {
          "Path": "/identity/{**catch-all}"
        },
        "ClusterId": "identity-cluster",
        "Transforms": [
          {
            "PathRemovePrefix": "/identity"
          }
        ]
      },
      "profiles-route": {
        "Match": {
          "Path": "/profiles/{**catch-all}"
        },
        "ClusterId": "profiles-cluster",
        "Transforms": [
          {
            "PathRemovePrefix": "/profiles"
          }
        ]
      },
      "files-route": {
        "Match": {
          "Path": "/files/{**catch-all}"
        },
        "ClusterId": "files-cluster",
        "Transforms": [
          {
            "PathRemovePrefix": "/files"
          }
        ]
      },
      "pets-route": {
        "Match": {
          "Path": "/pets/{**catch-all}"
        },
        "ClusterId": "pets-cluster",
        "Transforms": [
          {
            "PathRemovePrefix": "/pets"
          }
        ]
      },
      "notifications-route": {
        "Match": {
          "Path": "/notifications/{**catch-all}"
        },
        "ClusterId": "notifications-cluster",
        "Transforms": [
          {
            "PathRemovePrefix": "/notifications"
          }
        ]
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "identity-1": {
            "Address": "http://identity-service:80"
          }
        },
        "HttpRequest": {
          "Timeout": "00:00:30"
        }
      },
      "profiles-cluster": {
        "Destinations": {
          "profiles-1": {
            "Address": "http://user-profile-service:80"
          }
        },
        "HttpRequest": {
          "Timeout": "00:00:30"
        }
      },
      "files-cluster": {
        "Destinations": {
          "files-1": {
            "Address": "http://file-service:80"
          }
        },
        "HttpRequest": {
          "Timeout": "00:00:30"
        }
      },
      "pets-cluster": {
        "Destinations": {
          "pets-1": {
            "Address": "http://pet-service:80"
          }
        },
        "HttpRequest": {
          "Timeout": "00:00:30"
        }
      },
      "notifications-cluster": {
        "Destinations": {
          "notifications-1": {
            "Address": "http://notification-service:80"
          }
        },
        "HttpRequest": {
          "Timeout": "00:00:30"
        }
      }
    }
  }
}
